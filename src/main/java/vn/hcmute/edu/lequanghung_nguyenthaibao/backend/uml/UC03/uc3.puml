@startuml
left to right direction
skinparam packageStyle rectangle

actor "Khách truy cập\n(Guest)" as guest

package "Tìm kiếm và lọc cơ bản (UC03)" {
    usecase "Thiết lập cấu hình bộ lọc\n(areaId, minPrice, bedrooms...)" as UC_Filter
    usecase "Truy vấn CSDL\n(Chỉ lấy tin APPROVED)" as UC_Query

    usecase "Phân trang kết quả" as UC_Paginate
    usecase "Hiển thị thông báo rỗng" as UC_Empty
    usecase "Hiển thị tất cả tin mới nhất" as UC_All
}

' Thao tác của Actor
guest --> UC_Filter

' Mối quan hệ Include (Bắt buộc)
UC_Filter ..> UC_Query : <<include>>

' Mối quan hệ Extend (Luồng ngoại lệ / Mở rộng)
UC_Paginate .up.> UC_Query : <<extend>>\n[Dữ liệu trả về nhiều]
UC_Empty .up.> UC_Query : <<extend>>\n[0 matches]
UC_All .up.> UC_Query : <<extend>>\n[Để trống tìm kiếm]

@enduml