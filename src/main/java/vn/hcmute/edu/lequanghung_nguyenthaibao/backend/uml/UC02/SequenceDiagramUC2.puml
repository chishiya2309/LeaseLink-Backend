@startuml
autonumber
skinparam SequenceMessageAlign center

actor "Host" as User
participant "PropertyFormView" as View
participant "PropertyController" as Ctrl
participant "PropertyMediaService" as MediaService
participant "S3Service" as S3 <<Cloud>>
participant "PropertyService" as Service
participant "PropertyRepository" as Repo
participant "PropertyImage" as Entity
database "Database" as DB

== Khởi tạo Form ==
User -> View: Chọn "Đăng tin mới"
View --> User: Tải Form nhập liệu trống

== Nhập liệu & Gửi yêu cầu ==
User -> View: Điền thông tin & Đính kèm Ảnh/Video
note right of View: Max 10MB per file
User -> View: Nhấn "Lưu và Đăng xuất bản"

View -> Ctrl: createProperty(data, images, video)
activate Ctrl

== Validation (Bean Validation) ==
Ctrl -> Ctrl: @Valid: Check constraints\n(Title, Price, Area...)

alt Dữ liệu không hợp lệ
    Ctrl --> View: 400 Bad Request
    View --> User: Hiển thị lỗi tương ứng
else Dữ liệu hợp lệ

    == Upload Media (Async/Pre-persistence) ==
    Ctrl -> MediaService: uploadImages(images)
    activate MediaService
    MediaService -> S3: uploadFile(file)
    S3 --> MediaService: image_url
    MediaService --> Ctrl: List<String> urls
    deactivate MediaService

    == Lưu Cơ sở dữ liệu ==
    Ctrl -> Service: createProperty(data, urls, videoUrl, host)
    activate Service
    Service -> Repo: save(property)
    activate Repo
    Repo -> DB: INSERT INTO properties (status='PENDING')
    DB --> Repo: property_id
    deactivate Repo

    Service -> Entity: addImage(url)
    Service -> Repo: save(property)
    Service --> Ctrl: PropertyResponse
    deactivate Service

    == Phản hồi User ==
    Ctrl --> View: 201 Created
    View --> User: Điều hướng về màn hình Danh sách
end

deactivate Ctrl
@enduml