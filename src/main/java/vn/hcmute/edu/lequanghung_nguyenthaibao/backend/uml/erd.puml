@startuml
!theme plain
skinparam linetype ortho
skinparam shadowing false
skinparam roundcorner 5

' Force vertical layout for A4 friendliness
top to bottom direction

title LeaseLink Entity-Relationship Diagram (ERD)

package "Identity & Access Management (IAM)" #F8F9FA {
    entity "users" as users {
        * id : UUID <<PK>>
        --
        * full_name : VARCHAR(120)
        * email : VARCHAR(255) <<UQ>>
        phone : VARCHAR(20) <<UQ>>
        * password_hash : TEXT
        * status : USER_STATUS
        last_login_at : TIMESTAMPTZ
        * created_at : TIMESTAMPTZ
        * updated_at : TIMESTAMPTZ
        deleted_at : TIMESTAMPTZ
    }

    entity "roles" as roles {
        * id : SMALLINT <<PK>>
        --
        * code : VARCHAR(50) <<UQ>>
        * name : VARCHAR(120)
    }

    entity "permissions" as permissions {
        * id : BIGINT <<PK>>
        --
        * code : VARCHAR(100) <<UQ>>
        * name : VARCHAR(150)
    }

    entity "user_roles" as user_roles {
        * user_id : UUID <<FK>>
        * role_id : SMALLINT <<FK>>
    }

    entity "role_permissions" as role_permissions {
        * role_id : SMALLINT <<FK>>
        * permission_id : BIGINT <<FK>>
    }
}

package "Property Module" #E9ECEF {
    entity "properties" as properties {
        * id : UUID <<PK>>
        --
        * host_id : UUID <<FK>>
        * area_id : BIGINT <<FK>>
        * room_type_id : BIGINT <<FK>>
        * title : VARCHAR(255)
        description : TEXT
        * address_line : VARCHAR(255)
        * monthly_price : NUMERIC(14,2)
        area_m2 : NUMERIC(8,2)
        bedrooms : SMALLINT
        allow_pets : BOOLEAN
        * status : PROPERTY_STATUS
        approved_by : UUID <<FK>>
        approved_at : TIMESTAMPTZ
        rejected_reason : TEXT
        * created_at : TIMESTAMPTZ
        * updated_at : TIMESTAMPTZ
        deleted_at : TIMESTAMPTZ
    }

    entity "property_images" as property_images {
        * id : UUID <<PK>>
        --
        * property_id : UUID <<FK>>
        * image_url : TEXT
        * is_thumbnail : BOOLEAN
        * sort_order : INT
        * created_at : TIMESTAMPTZ
    }

    entity "areas" as areas {
        * id : BIGINT <<PK>>
        --
        * name : VARCHAR(120) <<UQ>>
        * slug : VARCHAR(150) <<UQ>>
        * is_active : BOOLEAN
    }

    entity "room_types" as room_types {
        * id : BIGINT <<PK>>
        --
        * name : VARCHAR(80) <<UQ>>
        * is_active : BOOLEAN
    }
}

package "Auth & Sessions" #DEE2E6 {
    entity "auth_sessions" as sessions {
        * id : UUID <<PK>>
        --
        * user_id : UUID <<FK>>
        device_id : VARCHAR(120)
        user_agent : TEXT
        ip : INET
        * is_active : BOOLEAN
        * created_at : TIMESTAMPTZ
        * last_seen_at : TIMESTAMPTZ
        * expires_at : TIMESTAMPTZ
    }

    entity "refresh_tokens" as tokens {
        * id : UUID <<PK>>
        --
        * session_id : UUID <<FK>>
        * user_id : UUID <<FK>>
        * token_hash : TEXT
        * jti : UUID <<UQ>>
        * issued_at : TIMESTAMPTZ
        * expires_at : TIMESTAMPTZ
        revoked_at : TIMESTAMPTZ
        replaced_by_token_id : UUID <<FK>>
        revoke_reason : VARCHAR(120)
    }

    entity "revoked_jtis" as revoked {
        * jti : UUID <<PK>>
        --
        * user_id : UUID <<FK>>
        * token_type : VARCHAR(20)
        * expires_at : TIMESTAMPTZ
        * revoked_at : TIMESTAMPTZ
    }
}

' Prevent overlapping packages by hinting the engine
"Identity & Access Management (IAM)" -[hidden]down- "Property Module"
"Property Module" -[hidden]down- "Auth & Sessions"

' Relationships
' Users relationships
users ||--down-o{ properties : "hosts"
users ||--down-o{ sessions : "has"
users ||--right-o{ property_images : "moderates"

' Properties relationships
properties ||--down-o{ property_images : "has"
properties }|--down--|| areas : "located in"
properties }|--down--|| room_types : "categorized as"
properties }o--up--|| users : "approved by"

' IAM relationships
users ||--down-o{ user_roles
roles ||--down-o{ user_roles
roles ||--down-o{ role_permissions
permissions ||--down-o{ role_permissions

' Auth & Sessions relationships
sessions ||--down-o{ tokens
users ||--down-o{ tokens
tokens ||--down-o| tokens : "replaced by"
users ||--down-o{ revoked

@enduml
