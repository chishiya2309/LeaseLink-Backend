@startuml
autonumber
skinparam SequenceMessageAlign center

actor "Guest" as User
participant "AiChatWidgetView" as View
participant "AiConversationController" as Ctrl
participant "GeminiNLPAiProvider\n(AiNLPService)" as NLP
participant "Gemini API" as API <<Cloud>>
participant "PropertySpecification" as Spec
participant "PropertyRepository" as Repo
database "Database" as DB

User -> View: Mở khung Chat & Nhập câu hỏi
User -> View: Nhấn Enter / Gửi tin

View -> View: Hiển thị Loading (Animation gõ chữ)

View -> Ctrl: POST /api/v1/ai/search\n{ message: "user_text" }
activate Ctrl

== Phân tích Text qua AI Model ==
Ctrl -> NLP: extractSearchCriteria(request.getMessage())
activate NLP
NLP -> NLP: getFullPrompt(prompt)\n(Ghép systemInstruction + prompt)
NLP -> API: POST /v1beta/models/gemini-2.5-flash:generateContent\n(requestBody + x-goog-api-key header)
activate API

alt A2: Lỗi kết nối / Timeout từ Cloud
    API --> NLP: Lỗi (Timeout / 500 / 429)
    NLP --> Ctrl: throw Exception
    Ctrl --> View: 503 SERVICE_UNAVAILABLE\n"Tính năng AI đang tạm gián đoạn..."
    View --> User: Bot xin lỗi, gợi ý dùng Bộ lọc (UC03)
else API phản hồi thành công
    API --> NLP: rawResponse (JSON String)
    deactivate API
    NLP -> NLP: Parse candidates[0].content.parts[0].text\nsang AiSearchCriteria (ObjectMapper)
    NLP --> Ctrl: AiSearchCriteria
deactivate NLP

== Kiểm tra Intent tìm kiếm BĐS ==
alt A1: isRealEstateQuery == false
    Ctrl --> View: 200 OK AiSearchResponse(\n"Tin nhắn không liên quan tới BĐS...",\ncriteria, emptyList)
    View --> User: Bot nói: "Bạn hãy mô tả nhu cầu tìm thuê..."
else isRealEstateQuery == true (hoặc null)

    == Build Specification & Truy vấn CSDL ==
    Ctrl -> Spec: buildBasicAndAiSpecification(criteria)
    activate Spec
    Spec --> Ctrl: Specification<Property>
    deactivate Spec

    Ctrl -> Repo: findAll(spec)
    activate Repo
    Repo -> DB: SELECT * FROM properties\nWHERE status='APPROVED' AND ...
    activate DB
    DB --> Repo: List<Property>
    deactivate DB
    Repo --> Ctrl: List<Property>
    deactivate Repo

    == Xếp hạng & Giới hạn kết quả ==
    Ctrl -> Ctrl: extractKeywords(criteria.keywordQuery)
    Ctrl -> Ctrl: sorted(buildSearchRankingComparator(keywords))\n.limit(MAX_RESULTS=10)\n.map(mapToResponse)

    == Tạo phản hồi thân thiện ==
    Ctrl -> Ctrl: generateReplyMessage(criteria, matchCount)
    Ctrl --> View: 200 OK AiSearchResponse(\nreplyMessage, criteria, List<PropertyResponse>)
    View --> User: Bot trả lời kèm Danh sách thẻ BĐS
end
end

deactivate Ctrl
@enduml