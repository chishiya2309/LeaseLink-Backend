@startuml
|Admin|
start
:Truy cập mục "Duyệt Bài";
|System|
:Truy xuất danh sách PENDING;
if (Danh sách còn bài?) then (Có)
  |Admin|
  repeat
    :Chọn 1 bài đăng trong danh sách;
    |System|
    :Hiển thị Modal chi tiết nội dung;
    |Admin|
    :Xem xét: Ảnh, Text, Giá, SĐT;
    if (Nội dung đạt chuẩn?) then (Có - Duyệt)
      :Nhấn Button "Duyệt tin ngay";
      |System|
      :Status = 'APPROVED';
      :Ghi Admin_ID, Time vào Property;
      :Gửi Notification "Tin đã được duyệt";
    else (Không - Từ chối)
      :Nhấn Button "Từ chối tin này";
      |System|
      :Hiển thị Popup lý do (Reason);
      |Admin|
      :Nhập lý do từ chối (Bắt buộc);
      :Xác nhận Từ chối;
      |System|
      :Status = 'REJECTED';
      :Lưu rejectedReason vào Property;
      :Ghi Admin_ID, Time vào Property;
      :Gửi Notification "Tin bị từ chối: [Lý do]";
    endif
    |System|
    :Ẩn bài vừa xử lý khỏi danh sách;
    :Thông báo kết quả (Toast);
  repeat while (Tiếp tục duyệt bài?) is (Đồng ý)
else (Không)
  :Thông báo "Hiện không có tin chờ duyệt";
endif
stop
@enduml
