@startuml
autonumber
skinparam SequenceMessageAlign center

actor "Người dùng" as User
participant "LoginPage /\nRegisterPage" as View
participant "UserController" as Ctrl
participant "UserServiceImpl" as Service
participant "UserRepository" as UserRepo
participant "RoleRepository" as RoleRepo
participant "AuthSessionRepository" as SessionRepo
participant "RefreshTokenRepository" as RefreshRepo
participant "PasswordEncoder" as Encoder
participant "JwtUtil" as JwtUtil
database "Database" as DB

== Luồng đăng ký host ==
User -> View: Mở trang Đăng ký
View --> User: Hiển thị form

User -> View: Nhập fullName, email, phone,\npassword, confirmPassword
User -> View: Nhấn "Đăng ký"
View -> View: Frontend validation

alt Frontend validation fail
    View --> User: Hiển thị lỗi cho người dùng tại form
else Frontend validation ok
    View -> Ctrl: POST /users/register
    activate Ctrl
        Ctrl -> Service: save(request)
        activate Service

            alt Password confirm không không khớp
                Service --> Ctrl: throw IllegalArgumentException
                Ctrl --> View: 400 Bad Request
            else Password confirm hop le
                Service -> UserRepo: existsByEmail(email)
                activate UserRepo
                    UserRepo -> DB: SELECT EXISTS BY email
                    DB --> UserRepo: true / false
                deactivate UserRepo

                alt Email đã tồn tại
                    Service --> Ctrl: throw ResourceAlreadyExistsException
                    Ctrl --> View: 400 Bad Request
                else Email hợp lệ
                    Service -> UserRepo: existsByPhone(phone)
                    activate UserRepo
                        UserRepo -> DB: SELECT EXISTS BY phone
                        DB --> UserRepo: true / false
                    deactivate UserRepo

                    alt Số điện thoại đã tồn tại
                        Service --> Ctrl: throw ResourceAlreadyExistsException
                        Ctrl --> View: 400 Bad Request
                    else Dữ liệu hợp lệ
                        Service -> Encoder: encode(password)
                        Encoder --> Service: passwordHash

                        Service -> RoleRepo: findByCode("HOST")
                        activate RoleRepo
                            RoleRepo -> DB: SELECT role HOST
                            DB --> RoleRepo: role HOST
                        deactivate RoleRepo

                        Service -> UserRepo: save(user status=PENDING, role=HOST)
                        activate UserRepo
                            UserRepo -> DB: INSERT users, user_roles
                            DB --> UserRepo: saved user
                        deactivate UserRepo

                        Service --> Ctrl: userId
                        Ctrl --> View: 201 Created
                    end
                end
            end
        deactivate Service
    deactivate Ctrl

    View --> User: Thông báo đăng ký thành công, chờ admin duyệt và chuyển hướng trang đăng nhập
end

== Luồng đăng nhập ==
User -> View: Mở trang Đăng nhập
View --> User: Hiển thị form

User -> View: Nhập email, password, role
User -> View: Nhấn "Đăng nhập"
View -> View: Frontend validation

alt Frontend validation fail
    View --> User: Hiển thị lỗi cho người dùng tại form
else Frontend validation ok
    View -> Ctrl: POST /users/login
    activate Ctrl
        Ctrl -> Service: login(request, httpRequest)
        activate Service

            Service -> UserRepo: findByEmail(email)
            activate UserRepo
                UserRepo -> DB: SELECT user by email
                DB --> UserRepo: user / null
            deactivate UserRepo

            alt Không tìm thấy user
                Service --> Ctrl: throw InvalidCredentialsException
                Ctrl --> View: 400/401 error
            else Tìm thấy user
                Service -> Encoder: matches(password, passwordHash)
                Encoder --> Service: true / false

                alt Password sai
                    Service --> Ctrl: throw InvalidCredentialsException
                    Ctrl --> View: 400/401 error
                else Password đúng
                    alt User bị khóa
                        Service --> Ctrl: throw AccountLockedException
                        Ctrl --> View: 400/403 error
                    else User hợp lệ
                        Service -> Service: Kiểm tra role được chọn trong user.roles

                        alt Role không thuộc user
                            Service --> Ctrl: throw InvalidCredentialsException
                            Ctrl --> View: 400/401 error
                        else Role hợp lệ
                            Service -> UserRepo: save(lastLoginAt)
                            UserRepo -> DB: UPDATE users

                            Service -> SessionRepo: save(AuthSession)
                            SessionRepo -> DB: INSERT auth_sessions
                            DB --> SessionRepo: saved session

                            Service -> Encoder: encode(refreshToken)
                            Encoder --> Service: refreshTokenHash

                            Service -> RefreshRepo: save(RefreshToken)
                            RefreshRepo -> DB: INSERT refresh_tokens

                            Service -> JwtUtil: generateAccessToken(user, role, sessionId)
                            JwtUtil --> Service: accessToken

                            Service --> Ctrl: LoginResponse(accessToken, refreshToken, user)
                            Ctrl --> View: 200 OK
                        end
                    end
                end
            end
        deactivate Service
    deactivate Ctrl

    View --> User: Lưu token và chuyển hướng sang trang chủ/dashboard
end

@enduml
