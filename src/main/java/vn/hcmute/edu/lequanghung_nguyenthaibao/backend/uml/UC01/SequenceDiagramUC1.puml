@startuml
autonumber
skinparam SequenceMessageAlign center

actor "Host/Admin/Guest" as User
participant "LoginView\n/ RegisterView" as View
participant "UserController" as Ctrl
participant "UserServiceImpl" as Service
participant "UserRepository" as Repos
participant "RoleRepository" as RoleRepos
database "Database" as DB

== Khởi tạo chức năng ==
User -> View: Truy cập trang Đăng ký
View --> User: Hiển thị Form Đăng ký

== Luồng 8.2 & 9.2: Đăng ký (Dành cho Chủ nhà) ==
User -> View: Nhập Thông tin (Tên, Email, SĐT, Pass, Confirm Pass...)
User -> View: Nhấn nút "Đăng ký"

View -> View: Frontend Validation (B1, B3)
activate View
    note right: Kiểm tra định dạng,\nô rỗng,...
deactivate View

View -> Ctrl: registerUser(UserRegisterRequest)
activate Ctrl
    Ctrl -> Service: save(request)
    activate Service
        
        alt B3: Password Confirm không khớp
            Service -> Service: validate password logic
            Service --> Ctrl: throw IllegalArgumentException
            Ctrl --> View: 400 Bad Request ("Mật khẩu không khớp")
        end

        Service -> Repos: existsByEmail(email)
        activate Repos
            Repos -> DB: SELECT EXISTS(...)
            activate DB
                DB --> Repos: true/false
            deactivate DB
            Repos --> Service: result
        deactivate Repos
        
        alt B2: Email đã tồn tại
            Service --> Ctrl: throw ResourceAlreadyExistsException
            Ctrl --> View: 409 Conflict ("Email đã đăng ký")
        end

        Service -> Repos: existsByPhone(phone)
        activate Repos
            Repos -> DB: SELECT EXISTS(...)
            activate DB
                DB --> Repos: true/false
            deactivate DB
            Repos --> Service: result
        deactivate Repos

        alt B5: Số điện thoại đã tồn tại
            Service --> Ctrl: throw ResourceAlreadyExistsException
            Ctrl --> View: 409 Conflict ("Số điện thoại đã đăng ký")
        end

        Service -> Service: passwordEncoder.encode(pass)
        
        Service -> RoleRepos: findByCode("HOST")
        activate RoleRepos
            RoleRepos -> DB: SELECT * FROM roles WHERE code='HOST'
            activate DB
                DB --> RoleRepos: RoleEntity
            deactivate DB
            RoleRepos --> Service: RoleEntity
        deactivate RoleRepos

        Service -> Repos: save(UserEntity)
        activate Repos
            Repos -> DB: INSERT INTO users ...
            activate DB
                DB --> Repos: UserRecord
            deactivate DB
            Repos --> Service: savedUser
        deactivate Repos
        
        Service --> Ctrl: userId
    deactivate Service
    Ctrl --> View: 201 Created (userId)
deactivate Ctrl

View --> User: Thông báo "Đăng ký thành công, chờ Admin duyệt"

@enduml