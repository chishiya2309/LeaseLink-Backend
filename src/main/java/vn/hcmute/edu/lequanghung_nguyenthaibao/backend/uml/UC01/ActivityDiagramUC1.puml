@startuml
skinparam conditionStyle inside
skinparam ActivityBackgroundColor #FEFECE
skinparam ActivityBorderColor #A80036

start
:Người dùng truy cập trang xác thực;

if (Lựa chọn chức năng?) then (Đăng nhập)
    :Hệ thống hiển thị form Đăng nhập;
    :Người dùng nhập Email, Mật khẩu, chọn Role;

    if (Frontend validation sai?) then (Có)
        :Hiển thị lỗi validate;
        stop
    else (Không)
        :Gửi POST /users/login;
        :Tim user theo email;

        if (Không tìm thấy user?) then (Có)
            :Trả lời "Tài khoản hoặc mật khẩu không chính xác";
            stop
        else (Không)
            :Đối chiếu passwordHash;

            if (Password sai?) then (Có)
                :Trả lời "Tài khoản hoặc mật khẩu không chính xác";
                stop
            else (Không)
                if (Status = LOCKED?) then (Có)
                    :Trả lời "Tài khoản của bạn đã bị khóa. Vui lòng liên hệ Admin để hỗ trợ.";
                    stop
                else (Không)
                    :Kiểm tra role được chọn có tồn tại trong user.roles;

                    if (Role không hợp lệ?) then (Có)
                        :Tra loi "Tài khoản không có quyền truy cập với vai trò này";
                        stop
                    else (Không)
                        :Cập nhật last_login_at;
                        :Tạo AuthSession;
                        :Sinh Refresh Token và lưu DB;
                        :Sinh Access Token;
                        :Trả về accessToken, refreshToken, user;
                        :Frontend lưu token va chuyển hướng;
                        stop
                    endif
                endif
            endif
        endif
    endif

else (Dang ky Host)
    :He thong hien thi form Dang ky;
    :Nguoi dung nhap Ho ten, Email, So dien thoai,\nMat khau, Xac nhan mat khau;

    if (Frontend validation sai?) then (Co)
        :Hien thi loi validate;
        stop
    else (Khong)
        :Gui POST /users/register;

        if (Password va Confirm khong khop?) then (Co)
            :Tra loi "Xac nhan mat khau khong khop";
            stop
        else (Khong)
            :Kiem tra email da ton tai;

            if (Email da ton tai?) then (Co)
                :Tra loi "Email nay da duoc dang ky";
                stop
            else (Khong)
                :Kiem tra so dien thoai da ton tai;

                if (So dien thoai da ton tai?) then (Co)
                    :Tra loi "So dien thoai nay da duoc dang ky";
                    stop
                else (Khong)
                    :Ma hoa mat khau bang BCrypt;
                    :Gan role HOST;
                    :Luu user voi status = PENDING;
                    :Tra thong bao dang ky thanh cong;
                    stop
                endif
            endif
        endif
    endif
endif

@enduml
