@startuml
skinparam conditionStyle inside
skinparam ActivityBackgroundColor #FEFECE
skinparam ActivityBorderColor #A80036

start
:Guest mở Tab / Popup "AI Assistant";
:Hệ thống hiển thị giao diện Chatbot\n(Kèm các Chip Prompt gợi ý nhanh);

repeat
    :Guest nhập câu hỏi (Plain text tự nhiên)\nvà nhấn Enter;

    :Hiển thị Loading Indicator (Animation gõ chữ);
    :Backend gửi message kèm System Prompt\nđến GeminiNLPAiProvider\n(POST Gemini API);

    if (Kết nối Gemini API? [Ngoại lệ A2]) then (Lỗi / Timeout)
        :Trả về 503 SERVICE_UNAVAILABLE\n"Tính năng AI đang tạm gián đoạn...";
        :Định hướng Guest sử dụng\nTìm kiếm bộ lọc (UC03);
        stop
    else (Thành công)
        :GeminiNLPAiProvider parse response\ntừ candidates[0] sang AiSearchCriteria;

        if (isRealEstateQuery == false? [Ngoại lệ A1]) then (Không phải BĐS)
            :Trả về AiSearchResponse:\n"Tin nhắn không liên quan tới BĐS,\nhãy mô tả nhu cầu thuê phòng nhé!";
        else (Đúng là tìm BĐS)
            :PropertySpecification.buildBasicAndAiSpecification(criteria)\nTạo Specification<Property> với các predicate AND;
            :PropertyRepository.findAll(spec)\nTruy vấn DB chỉ lấy status = APPROVED;
            :extractKeywords(criteria.keywordQuery)\nTách keyword từ keywordQuery;
            :Sắp xếp kết quả bằng buildSearchRankingComparator\n(ưu tiên keyword match title > description)\nGiới hạn MAX_RESULTS = 10;
            :generateReplyMessage(criteria, matchCount)\nGhép chuỗi phản hồi thân thiện;
            :Trả về AiSearchResponse\n(replyMessage, extractedCriteria, List<PropertyResponse>);
        endif
    endif

repeat while (Guest tiếp tục chat?) is (Có)

stop
@enduml