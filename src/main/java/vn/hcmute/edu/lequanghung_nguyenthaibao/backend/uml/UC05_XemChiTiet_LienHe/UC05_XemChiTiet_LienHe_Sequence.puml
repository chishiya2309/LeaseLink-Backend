@startuml
title UC05: Sequence Diagram - Xem chi tiết và Liên hệ

actor "Guest (Khách thuê)" as Guest
participant "Frontend (React)" as FE
participant "PropertyController" as Controller
participant "PropertyService" as Service
participant "PropertyRepository" as Repo
database "PostgreSQL" as DB

== Xem chi tiết bất động sản ==

Guest -> FE : Click vào thẻ bài đăng
FE -> Controller : GET /api/v1/properties/{id}
activate Controller

Controller -> Service : getProperty(id)
activate Service

Service -> Repo : findById(id)
activate Repo
Repo -> DB : SELECT * FROM properties WHERE id=?
DB --> Repo : Dữ liệu bài đăng
Repo --> Service : Property Entity
deactivate Repo

alt Bài đăng tồn tại
    Service --> Controller : PropertyResponse
    Controller --> FE : 200 OK (Data)
    FE --> Guest : Hiển thị trang Chi tiết
else Lỗi / Không tồn tại
    Service --> Controller : Exception / null
    Controller --> FE : 404 Not Found / 500
    FE --> Guest : Hiển thị lỗi: "Tin không khả dụng"
end

deactivate Service
deactivate Controller

== Liên hệ chủ nhà ==

Guest -> FE : Click "Zalo" hoặc "WhatsApp"
FE -> FE : window.open("https://zalo.me/...")
FE --> Guest : Chuyển hướng sang ứng dụng liên kết

@enduml
