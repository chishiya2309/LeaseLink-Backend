@startuml
left to right direction
skinparam packageStyle rectangle

actor "Khách vãng lai\n(Guest)" as guest
actor "Chủ nhà\n(Host)" as host
actor "Quản trị viên\n(Admin)" as admin

package "Hệ thống Bất Động Sản (UC01)" {
    usecase "Đăng ký Chủ nhà" as UC_Register
    usecase "Đăng nhập" as UC_Login

    usecase "Xác thực danh tính\n(Check DB & Hash)" as UC_Auth
    usecase "Kiểm tra trạng thái\n(Role & Status)" as UC_CheckStatus

    usecase "Hiển thị lỗi\n(Sai pass/Bị khóa/Chờ duyệt)" as UC_ShowError
}

' Định nghĩa các luồng tương tác của Actor
guest --> UC_Register
host --> UC_Login
admin --> UC_Login

' Các mối quan hệ Include (Bắt buộc phải có)
UC_Login ..> UC_Auth : <<include>>
UC_Login ..> UC_CheckStatus : <<include>>
UC_Register ..> UC_Auth : <<include>> (Validation)

' Các mối quan hệ Extend (Luồng ngoại lệ)
UC_ShowError .up.> UC_Login : <<extend>>\n[Nếu lỗi validation/trạng thái]
UC_ShowError .up.> UC_Register : <<extend>>\n[Nếu trùng Email/Sai pass]

@enduml