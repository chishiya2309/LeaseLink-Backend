@startuml
left to right direction
skinparam packageStyle rectangle

actor "Khách vãng lai\n(Guest)" as guest
actor "Chủ nhà\n(Host)" as host
actor "Quản trị viên\n(Admin)" as admin

package "Hệ thống Bất Động Sản (UC01)" {
    usecase "Đăng ký tài khoản\n(Chủ nhà)" as UC_Register
    usecase "Xác thực dữ liệu\n(Email/SĐT/Pass)" as UC_Validate
    usecase "Lưu thông tin & Gán quyền\n(Role HOST, Status PENDING)" as UC_Persist
    usecase "Hiển thị thông báo lỗi" as UC_ShowError
}

' Định nghĩa các luồng tương tác của Actor
guest --> UC_Register

' Các mối quan hệ Include (Bắt buộc phải có)
UC_Register ..> UC_Validate : <<include>>
UC_Register ..> UC_Persist : <<include>>

' Các mối quan hệ Extend (Luồng ngoại lệ)
UC_ShowError .up.> UC_Register : <<extend>>\n[Nếu lỗi validation/trùng lặp]

@enduml