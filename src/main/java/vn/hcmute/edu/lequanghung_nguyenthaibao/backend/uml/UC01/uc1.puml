@startuml
left to right direction
skinparam packageStyle rectangle

actor "Khách vãng lai\n(Guest)" as guest
actor "Chủ nhà\n(Host)" as host
actor "Quản trị viên\n(Admin)" as admin

package "Hệ thống LeaseLink (UC01 - Xác thực tài khoản)" {
    usecase "Đăng ký tài khoản\n(Host)" as UC_Register
    usecase "Đăng nhập hệ thống" as UC_Login
    usecase "Kiểm tra dữ liệu đầu vào\n(email / phone / password / role)" as UC_Validate
    usecase "Kiểm tra trùng lặp\nEmail / Số điện thoại" as UC_CheckDuplicate
    usecase "Gán role HOST và\nlưu status PENDING" as UC_PersistRegister
    usecase "Thông báo cho Admin\n(New Host Registration)" as UC_NotifyAdmin
    usecase "Xác thực email / password" as UC_Authenticate
    usecase "Tạo AuthSession,\nRefresh Token, Access Token" as UC_IssueToken
    usecase "Trả thông báo lỗi" as UC_ShowError
}

guest --> UC_Register
guest --> UC_Login
host --> UC_Login
admin --> UC_Login

UC_Register ..> UC_Validate : <<include>>
UC_Register ..> UC_CheckDuplicate : <<include>>
UC_Register ..> UC_PersistRegister : <<include>>
UC_Register ..> UC_NotifyAdmin : <<include>>

UC_Login ..> UC_Validate : <<include>>
UC_Login ..> UC_Authenticate : <<include>>
UC_Login ..> UC_IssueToken : <<include>>

UC_ShowError .up.> UC_Register : <<extend>>\nNếu validation / duplicate sai
UC_ShowError .up.> UC_Login : <<extend>>\nNếu sai thông tin / role / bị khoá

note bottom of UC_PersistRegister
Role được gán mặc định là HOST
Status lưu vào database là PENDING
end note

note bottom of UC_IssueToken
Hệ thống tạo AuthSession, lưu Refresh Token
và trả Access Token + Refresh Token cho client
end note

@enduml
